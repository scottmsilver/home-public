# Backend daemon base URLs — supplied per deployment, never hardcoded.
[backends.gate]
base_url     = "http://127.0.0.1:8000"
service_user = "home-gateway@local"   # injected as X-Verified-User

[backends.pool]
base_url = "http://127.0.0.1:8080"

[backends.fans]
base_url = "http://127.0.0.1:8095"

# Optional: WiiM multiroom audio via the wiimd daemon. Omit to disable the Music tab.
[backends.music]
base_url = "http://127.0.0.1:8096"

[web]
bind           = "0.0.0.0:8099"
remote_domain  = ""                    # e.g. "home.i.oursilverfamily.com"; empty = LAN-only
broker_url     = "https://auth.oursilverfamily.com"
allowed_emails = []                    # e.g. ["you@gmail.com"]

# Which controls surface on the unified Home card. One section (card) per row.
[[home.rows]]
domain = "gate"
doors  = ["Gate"]
title  = "Gate"

[[home.rows]]
domain   = "pool"
circuits = ["spa", "spa_setpoint", "lights"]
title    = "Spa"

[[home.rows]]
domain = "fans"
groups = ["fans", "lights", "heaters"]
title  = "Patio"
